# Variables requises par docker-compose.prod.yml. Copier vers .env.prod (jamais commité),
# remplir les valeurs, puis lancer :
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Nom de domaine réel pointant vers ce serveur (Caddy obtient automatiquement un
# certificat Let's Encrypt pour ce domaine). Mettre "localhost" uniquement pour un test
# local sans TLS.
DOMAIN=changeme.example.com

# Identifiants Postgres — ne jamais reprendre ceux du docker-compose.yml de développement.
POSTGRES_USER=dtransfert
POSTGRES_PASSWORD=changeme-generer-un-mot-de-passe-fort
POSTGRES_DB=dtransfert

# Générer avec : openssl rand -hex 32
# app/core/config.py refuse de démarrer en production si cette valeur reste celle par
# défaut du dépôt.
JWT_SECRET_KEY=changeme-generer-avec-openssl-rand-hex-32

# Mot de passe initial du compte Super Admin (matricule ADMIN), utilisé uniquement lors de sa
# création (si le compte n'existe pas encore). Un changement de mot de passe fait ensuite
# depuis l'interface d'administration n'est jamais écrasé par cette valeur.
SUPER_ADMIN_INITIAL_PASSWORD=changeme-generer-un-mot-de-passe-fort

# Laisser tel quel sauf besoin spécifique.
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
MAX_UPLOAD_SIZE_MB=10

# Sauvegardes base de donnees
# Dossier local sur l'hebergeur qui recevra les dumps compresses.
BACKUP_DIR=./backups
# Nombre de sauvegardes a conserver dans le dossier ci-dessus.
BACKUP_RETENTION_COUNT=14
# Laisse ces valeurs si tu utilises les scripts fournis.
COMPOSE_FILE=docker-compose.prod.yml
ENV_FILE=.env.prod

# Ne passer à "true" que temporairement si le domaine n'a pas encore de certificat TLS
# (Caddy n'a alors pas fini de le provisionner) — jamais en usage normal.
COOKIE_INSECURE=false

# Optionnel : stockage partagé (Redis) du rate limiting, nécessaire dès que plusieurs
# instances backend tournent derrière un load balancer. Laisser vide pour un compteur en
# mémoire par processus (suffisant pour une seule instance).
REDIS_URL=
